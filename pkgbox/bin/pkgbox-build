#!/bin/bash
source lib/rootfs.sh 
source lib/oci.sh
source lib/pkg.sh

if [ -z "$PKGBOX_HOME" ]; then
    PKGBOX_HOME=/tmp/pkgbox
fi

SPEC_DIR=$1
BUILD_NAME=$2

if [ -z "$SPEC_DIR" ]; then
  echo "Missing positional argument: SPEC_DIR."
  exit 1
fi

if [ -z "$BUILD_NAME" ]; then
  echo "Missing positional argument: BUILD_NAME"
 exit 1
fi 

echo "Using spec dir \"$SPEC_DIR\""

if [ ! -f "$SPEC_DIR/pkgbox.spec.bash" ]; then
  echo "Missing spec file \"$SPEC_DIR/pkgbox.spec.bash\"."
fi

echo "Using spec file \"$SPEC_DIR/pkgbox.spec.bash\""

source $SPEC_DIR/pkgbox.spec.bash

echo "Parent Layers: ${PKGBOX_DEPENDS[@]}"

PKGBOX_BUILD_DIR=$(mktemp -d)

echo "Build Dir: $PKGBOX_BUILD_DIR"

rootfs::apply ${PKGBOX_DEPENDS[@]} $PKGBOX_BUILD_DIR

oci::runtime::config::gen $PKGBOX_BUILD_DIR

mkdir -p  $PKGBOX_BUILD_DIR/{userdata,builddata}
cp -aR $SPEC_DIR $PKGBOX_BUILD_DIR/userdata/pkgbox-build

rootfs::tree::snapshot $PKGBOX_BUILD_DIR before.tree

crun run --bundle=$PKGBOX_BUILD_DIR pkgbox-build-$(basename $SPEC_DIR)

rootfs::tree::snapshot $PKGBOX_BUILD_DIR after.tree

rootfs::tree::diff $PKGBOX_BUILD_DIR

# mkdir -p $PKGBOX_HOME/oci/layers

# oci image-layer archive
# cp -aR $PKGBOX_BUILD_DIR/diff $PKGBOX_HOME/oci/layers/$BUILD_NAME/
(
  cd $PKGBOX_BUILD_DIR/diff;
  tar \
    --sort=name \
    --mtime='@0' \
    --xattrs \
    --pax-option=exthdr.name=%d/PaxHeaders/%f,delete=atime,delete=ctime \
    -cvf \
    $PKGBOX_BUILD_DIR/diff.tar .;
)

sha=$(sha256sum $PKGBOX_BUILD_DIR/diff.tar | awk '{print $1}')
mv $PKGBOX_BUILD_DIR/diff.tar $PKGBOX_HOME/oci/image-layers/$sha.tar

# artifact
mkdir -p $PKGBOX_HOME/artifacts/$BUILD_NAME
cp -aR $SPEC_DIR $PKGBOX_HOME/artifacts/$BUILD_NAME/src

if [ ! -f $PKGBOX_HOME/artifacts/$BUILD_NAME/$sha.tar ]; then
  ln -s $PKGBOX_HOME/oci/image-layers/$sha.tar $PKGBOX_HOME/artifacts/$BUILD_NAME/$sha.tar
fi

if [ -f $PKGBOX_HOME/artifacts/$BUILD_NAME/latest.tar ]; then
  unlink $PKGBOX_HOME/artifacts/$BUILD_NAME/latest.tar
fi
ln -s $PKGBOX_HOME/oci/image-layers/$sha.tar $PKGBOX_HOME/artifacts/$BUILD_NAME/latest.tar
