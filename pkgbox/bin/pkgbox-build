#!/bin/bash
source lib/container.sh

if [ -z "$PKGBOX_HOME" ]; then
    PKGBOX_HOME=/tmp/pkgbox
fi

BASEDIR=$PKGBOX_HOME/buildroots
NAME=$1
SPEC_DIR=$2

if [ -z $NAME ]; then
    echo "Missing buildbox name."
    exit 1
fi

if [ -z $SPEC_DIR ]; then
    echo "Missing spec dir path."
    exit 1
fi

### Prepare
container::create $BASEDIR/$NAME pkgbox-buildbox-$NAME $SPEC_DIR
###

### Build
container::exec pkgbox-buildbox-$NAME /tmp/pkgbox/build/pkgbox.spec.bash pkgbox::prepare
###

### Archive
#
###

### Cleanup
container::delete pkgbox-buildbox-$NAME
###
