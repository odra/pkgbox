#!/bin/bash
source lib/pkg.sh

if [ -z "$PKGBOX_HOME" ]; then
    PKGBOX_HOME=/tmp/pkgbox
fi

SPEC_DIR=$1

if [ -z "$SPEC_DIR" ]; then
  echo "Missing positional argument: SPEC_DIR."
  exit 1
fi

echo "Using spec dir \"$SPEC_DIR\""

if [ ! -f "$SPEC_DIR/pkgbox.spec.bash" ]; then
  echo "Missing spec file \"$SPEC_DIR/pkgbox.spec.bash\"."
fi

echo "Using spec file \"$SPEC_DIR/pkgbox.spec.bash\""

source $SPEC_DIR/pkgbox.spec.bash

echo "Parent Layers: ${PKGBOX_DEPENDS[@]}"

PKGBOX_BUILD_DIR=$(mktemp -d)

echo "Build Dir: $PKGBOX_BUILD_DIR"

mkdir -p $PKGBOX_BUILD_DIR/rootfs
for diff in ${PKGBOX_DEPENDS[@]}; do
  cp -R $PKGBOX_HOME/buildboxes/$diff/rootfs/* $PKGBOX_BUILD_DIR/rootfs
done

cfg=$(cat etc/config.json)
read -r -d '' userdata << EOM
{ 
  "destination": "/opt/pkgbox-build",
  "type": "bind",
  "source": "$PKGBOX_BUILD_DIR/userdata/pkgbox-build",
  "options": [
    "bind",
    "rprivate"
  ]
}
EOM
cfg=$(echo $cfg | jq ".mounts[.mounts | length] |= . + $userdata")
echo $cfg | jq > $PKGBOX_BUILD_DIR/config.json

mkdir -p  $PKGBOX_BUILD_DIR/{userdata,builddata}
cp -aR $SPEC_DIR $PKGBOX_BUILD_DIR/userdata/pkgbox-build

(cd /$PKGBOX_BUILD_DIR/rootfs; tree -ialf -I pkgbox-build) > $PKGBOX_BUILD_DIR/builddata/before.tree

crun run --bundle=$PKGBOX_BUILD_DIR pkgbox-build-$(basename $SPEC_DIR)

(cd /$PKGBOX_BUILD_DIR/rootfs; tree -ialf -I pkgbox-build) > $PKGBOX_BUILD_DIR/builddata/after.tree

diff $PKGBOX_BUILD_DIR/builddata/before.tree $PKGBOX_BUILD_DIR/builddata/after.tree > $PKGBOX_BUILD_DIR/builddata/tree.diff

./bin/pkgbox-tree-diff $PKGBOX_BUILD_DIR/builddata/tree.diff > $PKGBOX_BUILD_DIR/builddata/rootfs.diff.txt
